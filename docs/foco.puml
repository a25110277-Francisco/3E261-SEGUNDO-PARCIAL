@startuml foco

class Usuario
class Foco
class EstadoFoco
class SerieFoco

Usuario o-- Foco
Foco *-- EstadoFoco
EstadoFoco --|> Booleano
SerieFoco "1" *-- "10" Foco
Usuario o-- SerieFoco

class Foco{
    - EstadoFoco estado
    + Encender()
    + Apagar()
    + LeerEstado() : EstadoFoco
}

class SerieFoco{
    - Foco focos[10]
    + MostrarFocos()
    + EncenderFocos()
    + ApagarFocos()
}

@enduml